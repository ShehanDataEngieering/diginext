# Copy to .env and fill in with values from your Clerk dashboard (clerk.com).
# Never commit the real .env file - it's already in .gitignore.

# Renderer-side: safe to expose, identifies which Clerk app to talk to.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Main-process only: used to verify session tokens server-side. Keep secret.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Main-process only: comma-separated list of email addresses allowed into the
# app, checked after Clerk verifies the session token. This is what actually
# decides "who's allowed in" - Clerk's dashboard allowlist needs a paid plan,
# so we enforce it here for free. Leave empty to trust any verified Clerk
# session (not recommended once you have real data to protect).
ALLOWED_EMAILS=you@example.com

# Main-process only, optional, one-time use: absolute path to the existing
# "Master_Inventory final.xlsx" workbook. On launch, if the database has no
# items yet, its contents are imported so you start with real data instead of
# an empty app (see src/main/db/maybeSeed.ts). Once the database has data,
# this is ignored - safe to leave set or remove either way.
SEED_XLSX_PATH=/absolute/path/to/Master_Inventory final.xlsx
